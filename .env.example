# Database Configuration
# REQUIRED: PostgreSQL connection string with asyncpg driver
# Format: postgresql+asyncpg://username:password@host:port/database
# Example: postgresql+asyncpg://myuser:securepassword123@localhost:5432/mydatabase
# 
# Security Notes:
# - Never commit actual credentials to version control
# - Use strong passwords with mixed alphanumeric and special characters
# - For production, use managed database services with IAM authentication when possible
# - Consider using connection pooling (see Task 1 for implementation)
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/database_name

# Application will refuse to start if DATABASE_URL:
# - Is not set
# - Contains placeholder credentials (user:password)
# - Does not use postgresql:// or postgresql+asyncpg:// scheme
